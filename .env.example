# Slack webhook for LinkedIn bot notifications
SLACK_WEBHOOK_URL=

# SMTP settings if you prefer email notifications instead of, or in addition to, Slack
SMTP_HOST=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_TO=

# Slack bot setup
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
SLACK_BOT_STATE_FILE=.slack-chat-bot/state.json

# Shared OpenAI settings
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini
OPENAI_SYSTEM_PROMPT=

# Earth launch tracker
DATABASE_URL=
LAUNCH_SYNC_SECRET=
LAUNCH_TRACKER_APP_PORT=3001
LAUNCH_TRACKER_DATA_FILE=.launch-tracker-data.json
LAUNCH_LIBRARY_API_BASE=https://ll.thespacedevs.com/2.0.0
LAUNCH_LIBRARY_PAGE_SIZE=100
LAUNCH_SYNC_MAX_REQUESTS_PER_HOUR=15
LAUNCH_UPCOMING_STALE_MS=900000
LAUNCH_SYNC_LOCK_TTL_MS=600000

# Social scene finder
SOCIAL_SCENE_APP_PORT=3001
SOCIAL_SCENE_OPENAI_MODEL=gpt-5.4-mini

# Earnings call analyzer
ALPHA_VANTAGE_API_KEY=
SEC_USER_AGENT=earnings-call-analyzer/1.0 your-email@example.com
EARNINGS_OPENAI_MODEL=gpt-5-mini
